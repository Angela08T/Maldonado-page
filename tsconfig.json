{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "isolatedModules": true,
    "noEmit": true,

    /* JSX */
    "jsx": "react-jsx",
    "allowJs": true,

    /* Linting */
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
